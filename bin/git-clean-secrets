#!/usr/bin/env bash

# this is behaving like a hook but I don't want to deal with hook installation on all machines
# this gets pulled in with no additional setup
# disabled cause slow

data="$(cat)"

if secrets="$(<<<"$data" grep -En '(eyJ[A-Za-z0-9+/]{20,}|-----BEGIN .* PRIVATE KEY-----|ghp_|gho_|ghs_|xoxb-|xoxp-|AKIA[0-9A-Z]{16}|ATATT3xFfG)')"; then
    echo "Secret detected:" >&2
    echo "$secrets" >&2
    exit 1
fi

echo "$data"
