#!/usr/bin/env bash

# yolo
# https://docs.docker.com/engine/deprecated/#cli-plugins-support
# https://github.com/justincormack/nsenter1

if [[ "$1" == docker-cli-plugin-metadata ]]; then
    cat << EOF
{
     "SchemaVersion": "0.1.0",
     "Vendor": "https://jfx.ac",
     "Version": "v0.1.0",
     "ShortDescription": "(custom) get root on a Mac Docker VM"
}
EOF
    exit
fi

set -eu -o pipefail

cmd="$( builtin command -v docker &>/dev/null && echo docker || echo podman )"
"$cmd" run -it --rm --privileged --pid=host justincormack/nsenter1
