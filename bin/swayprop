#!/usr/bin/env bash

# https://gist.github.com/crispyricepc/f313386043395ff06570e02af2d9a8e0?permalink_comment_id=5321255#gistcomment-5321255

IFS=',x ' read -r x y w h < <(
    swaymsg -t get_tree \
    | jq -r '..
        | select(.pid? and .visible?)
        | .rect
        | "\(.x),\(.y) \(.width)x\(.height)"' \
    | slurp
)

swaymsg -t get_tree \
| jq -r \
    --argjson x "$x" \
    --argjson y "$y" \
    --argjson w "$w" \
    --argjson h "$h" \
    '..
    | select(.pid? and .visible?)
    | select(
        .rect.x      == $x and
        .rect.y      == $y and
        .rect.width  == $w and
        .rect.height == $h
    )'
