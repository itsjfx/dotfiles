#!/usr/bin/env bash

cmd="$(builtin command -v docker &>/dev/null && echo docker || echo podman)"

case "$1" in
    docker-cli-plugin-metadata)
        cat << EOF
{
     "SchemaVersion": "0.1.0",
     "Vendor": "https://jfx.ac",
     "Version": "v0.1.0",
     "ShortDescription": "(custom) run a shell on container"
}
EOF
        exit
        ;;
    # impl cobra style completion
    __complete)
        "$cmd" ps --format '{{.Names}}'$'\t''{{.Image}}'
        # NoFileComp
        echo ":4"
        exit
        ;;
esac

set -eu -o pipefail

cmd="$( builtin command -v docker &>/dev/null && echo docker || echo podman )"

container="$2"
shift 2

"$cmd" exec -it "$container" sh -c "[ -f /bin/bash ] && exec /bin/bash $@ || exec /bin/sh $@"
